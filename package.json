{
  "name": "@smolpack/eslint-config",
  "packageManager": "yarn@4.1.0",
  "version": "1.0.2",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SmolSoftBoi/eslint-config.git"
  },
  "type": "module",
  "main": "index.mjs",
  "scripts": {
    "lint:shell": "node ./scripts/lint-shell.mjs",
    "lint": "node ./scripts/lint.mjs",
    "typecheck": "node ./scripts/typecheck.mjs",
    "test": "node ./scripts/test.mjs",
    "preflight": "node ./scripts/prerelease/preflight.mjs",
    "pack:check": "node ./scripts/prerelease/pack-check.mjs",
    "smoke:import": "node ./scripts/prerelease/smoke-import.mjs",
    "smoke:pack": "bash ./scripts/smoke-import-packed.sh",
    "prerelease": "yarn preflight && yarn pack:check && yarn smoke:import",
    "release:validate": "node ./scripts/release/validate.mjs",
    "release:notes": "node ./scripts/release/notes.mjs",
    "release:prepare": "node ./scripts/release/prepare.mjs",
    "prepublishOnly": "yarn prerelease"
  },
  "keywords": [
    "eslint",
    "eslintconfig"
  ],
  "dependencies": {
    "typescript-eslint": "^8.62.0"
  },
  "peerDependencies": {
    "@eslint/js": ">=9.17.0 <11",
    "eslint": ">=9.17.0 <11",
    "eslint-config-prettier": ">=9.1.0",
    "eslint-import-resolver-typescript": ">= 3.7.0",
    "eslint-plugin-import-x": ">=4.16.2 <5",
    "typescript": ">=5.7.2 <6.1.0",
    "typescript-eslint": ">=8.57.2 <9"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@smolpack/prettier-config": "^1.0.5",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.17.1",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3"
  }
}
